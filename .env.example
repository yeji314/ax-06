# 필수 — OpenAI API
OPENAI_API_KEY=sk-...

# 권장 — 국토교통부 실거래가 API (data.go.kr 무료 발급)
# 활용 신청: 아파트 매매/전월세, 연립다세대 매매/전월세 4종 모두 신청
# 미설정 시 실거래 조회가 빈 결과를 반환합니다.
MOLIT_API_KEY=...

# 선택 — Tavily 웹 검색 (https://app.tavily.com 무료 발급)
# 추천 멘트 생성 시 동네 정보 컨텍스트로 사용합니다.
TAVILY_API_KEY=tvly-...

# 선택 — LangSmith 추적 (LLM 호출 모니터링)
LANGSMITH_API_KEY=ls__...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=real-estate-agent
